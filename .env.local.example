# ─── Monday.com ───────────────────────────────────────────────────────────────
# VITE_ prefix makes this available in the browser bundle (required by Vite)
VITE_MONDAY_API_KEY=your_monday_api_token_here

# Board IDs are already hardcoded in api/monday.ts:
#   Evaluation (Nye Leads)         → 5052697723
#   Sales (Zari's salg)            → 5089650058
#   Aftercare                      → 5052958230

# ─── Meta (Facebook/Instagram) Ads ───────────────────────────────────────────
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_your_ad_account_id

# ─── Google Ads ───────────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_CLIENT_ID=your_oauth2_client_id
GOOGLE_ADS_CLIENT_SECRET=your_oauth2_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_oauth2_refresh_token
GOOGLE_ADS_CUSTOMER_ID=your_customer_id_without_dashes

# ─── App settings ─────────────────────────────────────────────────────────────
SURGERY_PRICE_DEFAULT=40000
SOCO_BASE_FEE=5000
SOCO_COMMISSION_RATE=0.10
